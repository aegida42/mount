<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.drp.vpn_mount_drp</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/drp/vpn_mount_drp.sh</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>30</integer>

  <key>StandardOutPath</key>
  <string>/Users/drp/Library/Logs/vpn_mount_drp.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/drp/Library/Logs/vpn_mount_drp.err</string>
</dict>
</plist>
